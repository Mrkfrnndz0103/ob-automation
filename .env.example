## WF2.1 Drive CSV Consolidation (standalone)
##
## Copy to .env and fill in values.

# Required Google creds (choose one):
WF21_GOOGLE_CREDENTIALS_FILE=
# WF21_GOOGLE_CREDENTIALS_JSON=

# Cloudflare R2 (required)
WF21_R2_ACCOUNT_ID=
WF21_R2_BUCKET=
WF21_R2_ACCESS_KEY_ID=
WF21_R2_SECRET_ACCESS_KEY=
WF21_R2_OBJECT_PREFIX=wf2-1

# Google Drive
WF21_DRIVE_PARENT_FOLDER_ID=

# Destination Google Sheet
WF21_DESTINATION_SHEET_ID=
WF21_DESTINATION_TAB_PENDING_RCV=pending_rcv
WF21_DESTINATION_TAB_PACKED_IN_ANOTHER_TO=packed_in_another_to
WF21_DESTINATION_TAB_NO_LHPACKING=no_lhpacking

# Execution
WF21_CONTINUOUS=true
WF21_POLL_INTERVAL_SECONDS=1
WF21_DRY_RUN=false
WF21_BOOTSTRAP_PROCESS_EXISTING=true
WF21_DROP_LEADING_UNNAMED_COLUMN=true
WF21_SHEETS_BATCH_SIZE=7000

# Optional local files (defaults write under ./data)
# WF21_STATE_FILE=data/workflow2-1-drive-csv-consolidation-state.json
# WF21_STATUS_FILE=data/workflow2-1-drive-csv-consolidation-status.json

# Optional locking (local or R2 via r2://key)
# WF21_LOCK_FILE=data/wf21.lock
# WF21_LOCK_STALE_AFTER_SECONDS=1200

# Health server
WF21_ENABLE_HEALTH_SERVER=true
PORT=8080

# Summary snapshot + SeaTalk (optional)
WF21_SUMMARY_SEND_ENABLED=true
WF21_SUMMARY_SEATALK_MODE=bot  # bot|webhook
WF21_SEATALK_APP_ID=
WF21_SEATALK_APP_SECRET=
WF21_SEATALK_BASE_URL=https://openapi.seatalk.io
WF21_SEATALK_GROUP_ID=
# WF21_SEATALK_GROUP_IDS=
WF21_SEATALK_WEBHOOK_URL=
WF21_SUMMARY_SHEET_ID=
WF21_SUMMARY_TAB=[SOC] Backlogs Summary
WF21_SUMMARY_RANGE=B2:Q59
WF21_SUMMARY_SYNC_CELL=config!B1
WF21_SUMMARY_WAIT_SECONDS=8

# PDF->PNG rendering (optional; requires pdftoppm or ImageMagick when using pdf_png)
WF21_SUMMARY_RENDER_MODE=pdf_png  # styled|pdf_png
WF21_SUMMARY_PDF_CONVERTER=auto   # auto|pdftoppm|magick
WF21_SUMMARY_PDF_DPI=180

# New Relic logs (optional)
WF21_NEWRELIC_LOGS_ENABLED=false
WF21_NEWRELIC_LICENSE_KEY=

